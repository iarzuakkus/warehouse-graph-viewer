{
  "name": "@warehouse/desktop",
  "version": "0.1.0",
  "private": true,
  "author": "iarzuakkus",
  "type": "module",
  "description": "Warehouse Graph Viewer desktop application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && wait-on tcp:5173 && electron .",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "package:win": "npm run build && electron-builder --win",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@warehouse/api-client": "0.1.0",
    "@warehouse/domain": "0.1.0",
    "@warehouse/rendering-2d": "0.1.0",
    "@warehouse/rendering-3d": "0.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.warehouse.graphviewer",
    "productName": "Warehouse Graph Viewer",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
